{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "japanese",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(jq *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(xargs *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git status)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git push *)",
      "Bash(git worktree *)",
      "Bash(gh pr create --draft *)",
      "Bash(gh pr view *)",
      "Read(~/.claude/**)",
      "Read(~/.gradle/**)"
    ],
    "deny": [
      "Edit(*CLAUDE.local.md)",
      "Write(*CLAUDE.local.md)",
      "Edit(*settings.local.json)",
      "Write(*settings.local.json)",
      "Bash(rm:*)",
      "Bash(curl:*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard:*)",
      "Bash(wget:*)",
      "Bash(sudo:*)",
      "Read(**/.env)",
      "Edit(**/.env)",
      "Write(**/.env)"
    ],
    "ask": [
      "Bash(git push *main*)",
      "Bash(git push *master*)",
      "Bash(git push *release*)",
      "Bash(git push *develop*)",
      "Bash(git push *epic*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/allow-write-commands.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display dialog \"Permission request detected\" buttons {\"OK\"}'",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline/statusline.sh"
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": true,
    "document-skills@anthropic-agent-skills": true
  },
  "alwaysThinkingEnabled": false
}
