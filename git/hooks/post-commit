#!/bin/bash
# Run claude-setup.sh when files under claude/ (excluding README.md) are committed.

REPO_ROOT="$(git rev-parse --show-toplevel)"

changed=$(git diff-tree --name-only -r HEAD | grep '^claude/' | grep -v '^claude/README\.md')

if [ -n "$changed" ]; then
  echo "[post-commit] claude/ changes detected, running claude-setup.sh..."
  bash "$REPO_ROOT/claude/claude-setup.sh"
fi
