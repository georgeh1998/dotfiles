#alias
alias c="clear"
alias ya="yazi"
alias lgit="lazygit"

#prompt
autoload -Uz vcs_info
precmd() { vcs_info }
zstyle ':vcs_info:git:*' formats '<%b>'
setopt PROMPT_SUBST
PROMPT='%1~${vcs_info_msg_0_}: '

#export
export PATH="$HOME/Documents/dotfiles/bin:$PATH"

#sbx
csbx () {
  local name="claude-$(basename "$(pwd)" | tr '_' '-')"
  sbx create --name "$name" claude .
  sbx secret set -g github -t "$(gh auth token)"
  sbx run "$name"
}

csbxrm () {
  local name="claude-$(basename "$(pwd)" | tr '_' '-')"
  sbx rm "$name"
}
