#alias
alias c="clear"
alias ya="yazi"
alias lgit="lazygit"

#prompt
autoload -Uz vcs_info
precmd() { vcs_info }
zstyle ':vcs_info:git:*' formats '<%b>'
setopt PROMPT_SUBST
PROMPT='%1~${vcs_info_msg_0_}: '

#export
export PATH="$HOME/Documents/dotfiles/bin:$PATH"

#sbx
csbx () {
  local name="claude-$(basename "$(pwd)")"
  if sbx create --name "$name" claude . "$HOME/Desktop/screenshots:ro"; then
    sbx cp -L "$HOME/.claude/settings.json" "$name:/home/agent/.claude/settings.json"
    sbx cp -L "$HOME/.claude/skills"        "$name:/home/agent/.claude/skills"
    sbx cp -L "$HOME/.claude/hooks"         "$name:/home/agent/.claude/hooks"
    sbx cp -L "$HOME/.claude/statusline"    "$name:/home/agent/.claude/statusline"
    sbx cp -L "$HOME/.claude/agents"        "$name:/home/agent/.claude/agents"
  fi

  sbx run "$name"
}

csbxrm () {
  local name="claude-$(basename "$(pwd)")"
  sbx rm "$name"
}
