#alias
alias c="clear"
alias ya="yazi"
alias lgit="lazygit"

#prompt
autoload -Uz vcs_info
precmd() { vcs_info }
zstyle ':vcs_info:git:*' formats '<%b>'
setopt PROMPT_SUBST
PROMPT='%1~${vcs_info_msg_0_}: '

#export
export PATH="$HOME/Documents/dotfiles/bin:$PATH"

#sbx
csbx () {
  local name="claude-$(basename "$(pwd)" | tr '_' '-')"
  if sbx create --name "$name" claude .; then
    sbx secret set -f -g github -t "$(gh auth token)"
    
    cp -rL ~/.claude/skills /tmp/skills
    cp -rL ~/.claude/agents /tmp/agents
    sbx cp /tmp/skills "$name:/home/agent/.claude/skills"
    sbx cp /tmp/agents "$name:/home/agent/.claude/agents"
    rm -rf /tmp/claude-skills /tmp/claude-agents
  fi
  sbx run "$name"
}

csbxrm () {
  local name="claude-$(basename "$(pwd)" | tr '_' '-')"
  sbx rm "$name"
}
