#alias
alias c="clear"
alias ya="yazi"
alias lgit="lazygit"

#prompt
autoload -Uz vcs_info
precmd() { vcs_info }
zstyle ':vcs_info:git:*' formats '<%b>'
setopt PROMPT_SUBST
PROMPT='%1~${vcs_info_msg_0_}: '

#export
export PATH="$HOME/Documents/dotfiles/bin:$PATH"

#sbx
_cs_copy_config () {
  local name="$1"
  sbx secret set -f -g github -t "$(gh auth token)"
  cp -rL ~/.claude/skills /tmp/skills
  cp -rL ~/.claude/agents /tmp/agents
  sbx cp /tmp/skills "$name:/home/agent/.claude/skills"
  sbx cp /tmp/agents "$name:/home/agent/.claude/agents"
  rm -rf /tmp/skills /tmp/agents
}

cs () {
  local branch="${1}"
  local base="$(basename "$(pwd)" | tr '_' '-')"
  local name="$base-${branch:-default}"

  sbx rm "$name" 2>/dev/null
  if [ -n "$branch" ]; then
    sbx create --name "$name" --branch "$branch" claude .
  else
    sbx create --name "$name" claude .
  fi
  if [ $? -eq 0 ]; then
    _cs_copy_config "$name"
  fi
  sbx run "$name"
}

csrm () {
  local branch="${1:-default}"
  local base="$(basename "$(pwd)" | tr '_' '-')"
  sbx rm "$base-$branch"
}

csls () {
  local base="$(basename "$(pwd)" | tr '_' '-')"
  sbx ls | grep "$base"
}

set-cc-sbx () {
  local project_dir="$(pwd)"
  local target="${project_dir}/.claude/settings.local.json"
  local new_config
  new_config=$(jq -n \
    --arg path "$project_dir" \
    '{
      permissions: {
        allow: ["Read(*)", "Edit(*)", "Write(*)", "Bash(*)", "WebSearch", "WebFetch"],
        deny: [],
        ask: []
      },
      sandbox: {
        enabled: true,
        autoAllowBashIfSandboxed: true,
        allowUnsandboxedCommands: false,
        network: { allowLocalBinding: true, allowedDomains: ["*"] },
        filesystem: {
          allowWrite: [$path]
        }
      }
    }')

  mkdir -p "${project_dir}/.claude"

  if [ -f "$target" ]; then
    jq --argjson new "$new_config" '.sandbox = $new.sandbox | .permissions = $new.permissions' "$target" > "${target}.tmp" && mv "${target}.tmp" "$target"
    echo "Updated sandbox and permissions in $target"
  else
    echo "$new_config" > "$target"
    echo "Created $target"
  fi
}
