#!/bin/bash

# new-task - Quickly create a new task directory with spec.md template

set -e

# Check if task name is provided
if [ -z "$1" ]; then
    echo "Usage: new-task <task-name>"
    echo "Example: new-task SampleScreen"
    exit 1
fi

TASK_NAME="$1"

# Check if .claude directory exists
if [ ! -d ".claude" ]; then
    echo "Error: .claude directory not found."
    echo "Please run this command from the dotfiles directory."
    exit 1
fi

TASK_DIR=".claude/tasks/$TASK_NAME"

# Create task directory
mkdir -p "$TASK_DIR"

# Create spec.md template
cat > "$TASK_DIR/spec.md" <<EOF
# $TASK_NAME

## やりたいこと


## 調べてほしいこと

EOF

echo "Created task directory: $TASK_DIR"
